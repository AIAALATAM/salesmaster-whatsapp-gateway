PUBLIC_BASE_URL=https://wa.salesmasterplus.cloud
PORT=8086
NODE_ENV=production
ACTIVE_GATEWAY=QR

GATEWAY_SHARED_SECRET=replace-with-long-random-secret
REQUIRE_GATEWAY_SECRET=true
ALLOW_DEFAULT_TENANT=false
LOG_MESSAGE_BODIES=false

GHL_API_BASE=https://services.leadconnectorhq.com
GHL_VERSION=v3
GHL_INBOUND_TYPE=SMS
GHL_LOCATION_PIT=
GHL_TENANTS={"GHL_LOCATION_ID":{"pit":"GHL_LOCATION_PIT","instanceName":"client-instance","gateway":"QR","conversationProviderId":"OPTIONAL_PROVIDER_ID"}}

EVOLUTION_BASE_URL=http://evolution-api:8085
EVOLUTION_API_KEY=replace-with-long-random-evolution-key
EVOLUTION_INSTANCE_NAME=
EVOLUTION_POSTGRES_PASSWORD=replace-with-long-random-db-password

META_GRAPH_VERSION=v20.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=replace-with-meta-verify-token
META_APP_SECRET=
